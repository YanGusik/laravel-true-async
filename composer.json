{
  "name": "yangusik/laravel-spawn",
  "description": "Laravel adapter for PHP TrueAsync — async HTTP server with coroutine-per-request isolation",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.6",
    "laravel/framework": "^12.0 || ^13.0",
    "ext-pcntl": "*",
    "ext-pdo": "*"
  },
  "require-dev": {
    "inertiajs/inertia-laravel": "^3.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0",
    "spatie/laravel-permission": "^7.2"
  },
  "autoload": {
    "psr-4": {
      "Spawn\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Spawn\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Spawn\\Laravel\\AsyncServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
