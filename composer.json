{
    "name": "yangusik/laravel-true-async",
    "description": "Laravel adapter for PHP TrueAsync — async HTTP server with coroutine-per-request isolation",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.6",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "TrueAsync\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TrueAsync\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TrueAsync\\Laravel\\AsyncServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
